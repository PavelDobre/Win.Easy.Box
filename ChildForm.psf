  <Code><![CDATA[function Exit-App
{
	$script:AllowClose = $true
	Cleanup-App
	$formEasyBox.Close()
}

function Cleanup-App
{
	Save-AppSettings `
					 -Path $script:SettingsPath `
					 -checkboxРоссия $checkboxРоссия.Checked `
					 -CheckBox2 $checkBox2.Checked `
					 -SelectedFileName $script:SelectedFileName
	
	try
	{
		if ($timerStatus)
		{
			$timerStatus.Stop()
		}
		
		if ($script:SingBoxProcess -and -not $script:SingBoxProcess.HasExited)
		{
			Stop-Process -Id $script:SingBoxProcess.Id -Force
			$script:SingBoxProcess = $null
		}
	}
	catch
	{
	}
	
	try
	{
		$notifyicon1.Visible = $false
	}
	catch
	{
	}
}


<#
function Build-SingboxConfig
{
	[CmdletBinding()]
	param (
		[Parameter(Mandatory)]
		[string]$BaseConfigPath,
		[Parameter(Mandatory)]
		[string]$ProfilePath,
		[Parameter(Mandatory)]
		[string]$OutputPath,
		[string]$ProxyTag = "proxy",
		[switch]$ForceRouteFinalToProxy
	)
	
	function Read-JsonFile
	{
		param (
			[Parameter(Mandatory)]
			[string]$Path
		)
		
		if (-not (Test-Path -LiteralPath $Path))
		{
			throw "File not found: $Path"
		}
		
		try
		{
			$raw = Get-Content -LiteralPath $Path -Raw -Encoding UTF8
		}
		catch
		{
			throw "Failed to read file '$Path'. $($_.Exception.Message)"
		}
		
		if ([string]::IsNullOrWhiteSpace($raw))
		{
			throw "File is empty: $Path"
		}
		
		try
		{
			return $raw | ConvertFrom-Json
		}
		catch
		{
			throw "Failed to parse JSON in '$Path'. $($_.Exception.Message)"
		}
	}
	
	$baseConfig = Read-JsonFile -Path $BaseConfigPath
	$profile = Read-JsonFile -Path $ProfilePath
	
	if (-not ($baseConfig.PSObject.Properties.Name -contains 'outbounds'))
	{
		throw "Base config does not contain 'outbounds'."
	}
	
	if (-not ($profile.PSObject.Properties.Name -contains 'tag'))
	{
		throw "Profile JSON does not contain 'tag'."
	}
	
	if (-not ($profile.PSObject.Properties.Name -contains 'type'))
	{
		throw "Profile JSON does not contain 'type'."
	}
	
	### Normalize profile tag
	$profile.tag = $ProxyTag
	
	### Build new outbounds array:
	### keep all base outbounds except existing proxy outbound, then append selected profile
	$newOutbounds = @()
	
	foreach ($outbound in @($baseConfig.outbounds))
	{
		if ($null -eq $outbound) { continue }
		
		$existingTag = $null
		if ($outbound.PSObject.Properties.Name -contains 'tag')
		{
			$existingTag = $outbound.tag
		}
		
		if ($existingTag -ne $ProxyTag)
		{
			$newOutbounds += $outbound
		}
	}
	
	$newOutbounds += $profile
	$baseConfig.outbounds = @($newOutbounds)
	
	### Ensure route exists and optionally force final
	if ($ForceRouteFinalToProxy)
	{
		if (-not ($baseConfig.PSObject.Properties.Name -contains 'route') -or $null -eq $baseConfig.route)
		{
			$baseConfig | Add-Member -MemberType NoteProperty -Name route -Value ([pscustomobject]@{ }) -Force
		}
		
		if ($baseConfig.route.PSObject.Properties.Name -contains 'final')
		{
			$baseConfig.route.final = $ProxyTag
		}
		else
		{
			$baseConfig.route | Add-Member -MemberType NoteProperty -Name final -Value $ProxyTag -Force
		}
	}
	
	### Save final config
	try
	{
		$outputDir = Split-Path -Parent $OutputPath
		if ($outputDir -and -not (Test-Path -LiteralPath $outputDir))
		{
			New-Item -ItemType Directory -Path $outputDir -Force | Out-Null
		}
		
		$json = $baseConfig | ConvertTo-Json -Depth 100
		[System.IO.File]::WriteAllText($OutputPath, $json, [System.Text.UTF8Encoding]::new($false))
	}
	catch
	{
		throw "Failed to save output config to '$OutputPath'. $($_.Exception.Message)"
	}
	
	[pscustomobject]@{
		BaseConfig = $BaseConfigPath
		Profile    = $ProfilePath
		OutputFile = $OutputPath
		ProxyTag   = $ProxyTag
		RouteFinal = if ($baseConfig.route -and ($baseConfig.route.PSObject.Properties.Name -contains 'final')) { $baseConfig.route.final } else { $null }
		Outbounds  = @($baseConfig.outbounds).Count
	}
}
#>
function Build-SingboxConfig
{
	[CmdletBinding()]
	param (
		[Parameter(Mandatory)]
		[string]$BaseConfigPath,
		[Parameter(Mandatory)]
		[string]$ProfilePath,
		[Parameter(Mandatory)]
		[string]$OutputPath,
		[string]$ProxyTag = "proxy",
		[switch]$ForceRouteFinalToProxy
	)
	
	function Read-JsonFile
	{
		param (
			[Parameter(Mandatory)]
			[string]$Path
		)
		
		if (-not (Test-Path -LiteralPath $Path))
		{
			throw "File not found: $Path"
		}
		
		try
		{
			$raw = Get-Content -LiteralPath $Path -Raw -Encoding UTF8
		}
		catch
		{
			throw "Failed to read file '$Path'. $($_.Exception.Message)"
		}
		
		if ([string]::IsNullOrWhiteSpace($raw))
		{
			throw "File is empty: $Path"
		}
		
		try
		{
			return $raw | ConvertFrom-Json
		}
		catch
		{
			throw "Failed to parse JSON in '$Path'. $($_.Exception.Message)"
		}
	}
	
	### Select actual base config depending on checkbox state
	$selectedBaseConfigPath = $BaseConfigPath
	
	if ($checkboxРоссия.Checked -and $checkbox2.Checked)
	{
		$selectedBaseConfigPath = $baseconfigfileRusAd
	}
	elseif ($checkboxРоссия.Checked)
	{
		$selectedBaseConfigPath = $baseconfigfileRus
	}
	elseif ($checkbox2.Checked)
	{
		$selectedBaseConfigPath = $baseconfigfileAd
	}
	else
	{
		$selectedBaseConfigPath = $BaseConfigPath
	}
	
	$baseConfig = Read-JsonFile -Path $selectedBaseConfigPath
	$profile = Read-JsonFile -Path $ProfilePath
	
	if (-not ($baseConfig.PSObject.Properties.Name -contains 'outbounds'))
	{
		throw "Base config does not contain 'outbounds'."
	}
	
	if (-not ($profile.PSObject.Properties.Name -contains 'tag'))
	{
		throw "Profile JSON does not contain 'tag'."
	}
	
	if (-not ($profile.PSObject.Properties.Name -contains 'type'))
	{
		throw "Profile JSON does not contain 'type'."
	}
	
	### Normalize profile tag
	$profile.tag = $ProxyTag
	
	### Build new outbounds array:
	### keep all base outbounds except existing proxy outbound, then append selected profile
	$newOutbounds = @()
	
	foreach ($outbound in @($baseConfig.outbounds))
	{
		if ($null -eq $outbound) { continue }
		
		$existingTag = $null
		if ($outbound.PSObject.Properties.Name -contains 'tag')
		{
			$existingTag = $outbound.tag
		}
		
		if ($existingTag -ne $ProxyTag)
		{
			$newOutbounds += $outbound
		}
	}
	
	$newOutbounds += $profile
	$baseConfig.outbounds = @($newOutbounds)
	
	### Ensure route exists and optionally force final
	if ($ForceRouteFinalToProxy)
	{
		if (-not ($baseConfig.PSObject.Properties.Name -contains 'route') -or $null -eq $baseConfig.route)
		{
			$baseConfig | Add-Member -MemberType NoteProperty -Name route -Value ([pscustomobject]@{ }) -Force
		}
		
		if ($baseConfig.route.PSObject.Properties.Name -contains 'final')
		{
			$baseConfig.route.final = $ProxyTag
		}
		else
		{
			$baseConfig.route | Add-Member -MemberType NoteProperty -Name final -Value $ProxyTag -Force
		}
	}
	
	### Save final config
	try
	{
		$outputDir = Split-Path -Parent $OutputPath
		if ($outputDir -and -not (Test-Path -LiteralPath $outputDir))
		{
			New-Item -ItemType Directory -Path $outputDir -Force | Out-Null
		}
		
		$json = $baseConfig | ConvertTo-Json -Depth 100
		[System.IO.File]::WriteAllText($OutputPath, $json, [System.Text.UTF8Encoding]::new($false))
	}
	catch
	{
		throw "Failed to save output config to '$OutputPath'. $($_.Exception.Message)"
	}
	
	[pscustomobject]@{
		BaseConfig = $selectedBaseConfigPath
		Profile    = $ProfilePath
		OutputFile = $OutputPath
		ProxyTag   = $ProxyTag
		RouteFinal = if ($baseConfig.route -and ($baseConfig.route.PSObject.Properties.Name -contains 'final')) { $baseConfig.route.final } else { $null }
		Outbounds  = @($baseConfig.outbounds).Count
	}
}



function Get-SettingsPath
{
	
	return Join-Path $configsDir "settings.json"
}

function Load-AppSettings
{
	param (
		[string]$Path
	)
	
	if (Test-Path -LiteralPath $Path)
	{
		try
		{
			return (Get-Content -LiteralPath $Path -Raw -Encoding UTF8 | ConvertFrom-Json)
		}
		catch
		{
			# если файл битый настройки по умолчанию
		}
	}
	
	return [pscustomobject]@{
		CheckBox1	     = $false
		CheckBox2	     = $false
		SelectedFileName = ""
	}
}

function Save-AppSettings
{
	param (
		[string]$Path,
		[bool]$checkboxРоссия,
		[bool]$CheckBox2,
		[string]$SelectedFileName
	)
	
	$data = [ordered]@{
		CheckBox1	     = $checkboxРоссия
		CheckBox2	     = $CheckBox2
		SelectedFileName = $SelectedFileName
	}
	
	$json = $data | ConvertTo-Json # -Depth 5
	
	[System.IO.File]::WriteAllText(
		$Path,
		$json,
		[System.Text.UTF8Encoding]::new($false)
	)
}

function Update-SingBoxStatus
{
	try
	{
		if ($script:SingBoxProcess -and -not $script:SingBoxProcess.HasExited)
		{
			$uptime = (Get-Date) - $script:SingBoxProcess.StartTime
			
			$labelStatus.Text = "ВПН подключен"
			$labelStatus.ForeColor = [System.Drawing.Color]::Green
			
			$labelPid.Text = "PID: $($script:SingBoxProcess.Id)"
			$labelProfile.Text = "Profile: $($script:SingBoxProfileName)"
			$labelUptime.Text = "Uptime: {0:hh\:mm\:ss}" -f $uptime
			
			$buttonСтарт.Enabled = $false
			$buttonСтоп.Enabled = $true
		}
		else
		{
			$labelStatus.Text = "ВПН не подключен"
			$labelStatus.ForeColor = [System.Drawing.Color]::Red
			
			$labelPid.Text = "PID: -"
			$labelUptime.Text = "Uptime: -"
			$labelProfile.Text = "Profile: -"
			
			$buttonСтарт.Enabled = $true
			$buttonСтоп.Enabled = $false
			
			$script:SingBoxProcess = $null
			Hide-ExternalIpLabels
		}
	}
	catch
	{
		$labelStatus.Text = "Ошибка"
		$labelStatus.ForeColor = [System.Drawing.Color]::DarkOrange
		$labelPid.Text = "PID: -"
		$labelUptime.Text = "Uptime: -"
		Hide-ExternalIpLabels
	}
}

function Get-IpFromJsonEndpoint
{
	param (
		[Parameter(Mandatory)]
		[string]$Url
	)
	
	try
	{
		$response = Invoke-RestMethod -Uri $Url -Method Get -TimeoutSec 10
		return $response.ip
	}
	catch
	{
		return $null
	}
}


function Update-ExternalIpLabels
{
	try
	{
		$ipInt = Get-IpFromJsonEndpoint -Url $EUUrl
		$ipRus = Get-IpFromJsonEndpoint -Url $rusUrl
		
		if ($ipInt)
		{
			$labelipint.Text = "EU $ipInt"
		}
		else
		{
			$labelipint.Text = "IP not available"
		}
		
		if ($ipRus)
		{
			$labelipRus.Text = "RU $ipRus"
		}
		else
		{
			$labelipRus.Text = "IP not available"
		}
		
		$labelipint.Visible = $true
		$labelipRus.Visible = $true
	}
	catch
	{
		$labelipint.Text = "IP not available"
		$labelipRus.Text = "IP not available"
		$labelipint.Visible = $true
		$labelipRus.Visible = $true
	}
}

function Hide-ExternalIpLabels
{
	$labelipint.Visible = $false
	$labelipRus.Visible = $false
	$labelipint.Text = ""
	$labelipRus.Text = ""
}



$script:SingBoxProcess = $null
$script:SingBoxConfigPath = $null
$script:SingBoxProfileName = $null
$script:SingBoxStartTime = $null


$formEasyBox_Load = {
	$script:AllowClose = $false
	$buttonЗакрыть.DialogResult = [System.Windows.Forms.DialogResult]::None
	$buttonСвернуть.DialogResult = [System.Windows.Forms.DialogResult]::None
	$formEasyBox.AcceptButton = $null
	$formEasyBox.CancelButton = $null
	if (-not (Test-Path -LiteralPath $profilesDir))
	{
		[System.IO.Directory]::CreateDirectory($profilesDir) | Out-Null
	}
	
	$listBox1.Items.Clear()	
	Get-ChildItem -Path $profilesDir -File | ForEach-Object {
		$listbox1.Items.Add($_.Name)
	}
	$script:SettingsPath = Get-SettingsPath
	$settings = Load-AppSettings -Path $script:SettingsPath
		
		$checkboxРоссия.Checked = [bool]$settings.CheckBox1
		$checkBox2.Checked = [bool]$settings.CheckBox2
		
		$script:SelectedFileName = [string]$settings.SelectedFileName
		
		if (-not [string]::IsNullOrWhiteSpace($script:SelectedFileName))
		{
			$fullPath = Join-Path $profilesDir $script:SelectedFileName
			
			if (Test-Path -LiteralPath $fullPath)
			{
				$label1.Text = $script:SelectedFileName
			}
			else
			{
				$label1.Text = "Выберите"
			}
		}
		else
		{
			$label1.Text = "Выберите"
	}
	Hide-ExternalIpLabels
	$timerStatus.Start()
	Update-SingBoxStatus
	
	$script:IpUpdateTimer = New-Object System.Windows.Forms.Timer
	$script:IpUpdateTimer.Interval = 3000
	$script:IpUpdateTimer.add_Tick({
			$script:IpUpdateTimer.Stop()
			
			if ($script:SingBoxProcess -and -not $script:SingBoxProcess.HasExited)
			{
				Update-ExternalIpLabels
			}
		})
		
}



$buttonСтарт_Click={
	try
	{
		if ($script:SingBoxProcess -and -not $script:SingBoxProcess.HasExited)
		{
			[System.Windows.Forms.MessageBox]::Show("ВПН уже запущен.")
			return
		}
		
		$profilefile = Join-Path $profilesDir $label1.Text
		
		
		$script:SingBoxConfigPath = $configfile
		$script:SingBoxProfileName = $label1.Text
		
		Build-SingboxConfig -BaseConfigPath $baseconfigfile -ProfilePath $profilefile -OutputPath $configfile -ForceRouteFinalToProxy
		
		
		if (-not (Test-Path $logDir))
		{
			New-Item -ItemType Directory -Path $logDir | Out-Null
		}
		
		
		
		$script:SingBoxProcess = Start-Process -FilePath $singbox `
											   -ArgumentList "run -c `"$configfile`"" `
											   -RedirectStandardOutput $stdoutLog `
											   -RedirectStandardError $stderrLog `
											   -PassThru `
											   -WindowStyle Hidden
		
		Start-Sleep -Milliseconds 700
		$script:SingBoxProcess.Refresh()
		Update-SingBoxStatus
		$script:IpUpdateTimer.Stop()
		$script:IpUpdateTimer.Start()
	}
	catch
	{
		[System.Windows.Forms.MessageBox]::Show("Не удалось стартовать:`r`n$($_.Exception.Message)")
		Update-SingBoxStatus
		Hide-ExternalIpLabels
	}
}

#region Control Helper Functions
function Show-NotifyIcon
{
<#
	.SYNOPSIS
		Displays a NotifyIcon's balloon tip message in the taskbar's notification area.
	
	.DESCRIPTION
		Displays a NotifyIcon's a balloon tip message in the taskbar's notification area.
		
	.PARAMETER NotifyIcon
     	The NotifyIcon control that will be displayed.
	
	.PARAMETER BalloonTipText
     	Sets the text to display in the balloon tip.
	
	.PARAMETER BalloonTipTitle
		Sets the Title to display in the balloon tip.
	
	.PARAMETER BalloonTipIcon	
		The icon to display in the ballon tip.
	
	.PARAMETER Timeout	
		The time the ToolTip Balloon will remain visible in milliseconds. 
		Default: 0 - Uses windows default.
#>
	 param(
	  [Parameter(Mandatory = $true, Position = 0)]
	  [ValidateNotNull()]
	  [System.Windows.Forms.NotifyIcon]$NotifyIcon,
	  [Parameter(Mandatory = $true, Position = 1)]
	  [ValidateNotNullOrEmpty()]
	  [String]$BalloonTipText,
	  [Parameter(Position = 2)]
	  [String]$BalloonTipTitle = '',
	  [Parameter(Position = 3)]
	  [System.Windows.Forms.ToolTipIcon]$BalloonTipIcon = 'None',
	  [Parameter(Position = 4)]
	  [int]$Timeout = 0
 	)
	
	if($null -eq $NotifyIcon.Icon)
	{
		#Set a Default Icon otherwise the balloon will not show
		$NotifyIcon.Icon = [System.Drawing.Icon]::ExtractAssociatedIcon([System.Windows.Forms.Application]::ExecutablePath)
	}
	
	$NotifyIcon.ShowBalloonTip($Timeout, $BalloonTipTitle, $BalloonTipText, $BalloonTipIcon)
}




function Update-ListBox
{
<#
	.SYNOPSIS
		This functions helps you load items into a ListBox or CheckedListBox.
	
	.DESCRIPTION
		Use this function to dynamically load items into the ListBox control.
	
	.PARAMETER ListBox
		The ListBox control you want to add items to.
	
	.PARAMETER Items
		The object or objects you wish to load into the ListBox's Items collection.
	
	.PARAMETER DisplayMember
		Indicates the property to display for the items in this control.
		
	.PARAMETER ValueMember
		Indicates the property to use for the value of the control.
	
	.PARAMETER Append
		Adds the item(s) to the ListBox without clearing the Items collection.
	
	.EXAMPLE
		Update-ListBox $ListBox1 "Red", "White", "Blue"
	
	.EXAMPLE
		Update-ListBox $listBox1 "Red" -Append
		Update-ListBox $listBox1 "White" -Append
		Update-ListBox $listBox1 "Blue" -Append
	
	.EXAMPLE
		Update-ListBox $listBox1 (Get-Process) "ProcessName"
	
	.NOTES
		Additional information about the function.
#>
	
	param
	(
		[Parameter(Mandatory = $true)]
		[ValidateNotNull()]
		[System.Windows.Forms.ListBox]
		$ListBox,
		[Parameter(Mandatory = $true)]
		[ValidateNotNull()]
		$Items,
		[Parameter(Mandatory = $false)]
		[string]$DisplayMember,
		[Parameter(Mandatory = $false)]
		[string]$ValueMember,
		[switch]
		$Append
	)
	
	if (-not $Append)
	{
		$ListBox.Items.Clear()
	}
	
	if ($Items -is [System.Windows.Forms.ListBox+ObjectCollection] -or $Items -is [System.Collections.ICollection])
	{
		$ListBox.Items.AddRange($Items)
	}
	elseif ($Items -is [System.Collections.IEnumerable])
	{
		$ListBox.BeginUpdate()
		foreach ($obj in $Items)
		{
			$ListBox.Items.Add($obj)
		}
		$ListBox.EndUpdate()
	}
	else
	{
		$ListBox.Items.Add($Items)
	}
	
	if ($DisplayMember)
	{
		$ListBox.DisplayMember = $DisplayMember
	}
	if ($ValueMember)
	{
		$ListBox.ValueMember = $ValueMember
	}
}



function Update-ListViewColumnSort
{
<#
	.SYNOPSIS
		Sort the ListView's item using the specified column.
	
	.DESCRIPTION
		Sort the ListView's item using the specified column.
		This function uses Add-Type to define a class that sort the items.
		The ListView's Tag property is used to keep track of the sorting.
	
	.PARAMETER ListView
		The ListView control to sort.
	
	.PARAMETER ColumnIndex
		The index of the column to use for sorting.
	
	.PARAMETER SortOrder
		The direction to sort the items. If not specified or set to None, it will toggle.
	
	.EXAMPLE
		Update-ListViewColumnSort -ListView $listview1 -ColumnIndex 0
	
	.NOTES
		Additional information about the function.
#>
	
	param
	(
		[Parameter(Mandatory = $true)]
		[ValidateNotNull()]
		[System.Windows.Forms.ListView]
		$ListView,
		[Parameter(Mandatory = $true)]
		[int]
		$ColumnIndex,
		[System.Windows.Forms.SortOrder]
		$SortOrder = 'None'
	)
	
	if (($ListView.Items.Count -eq 0) -or ($ColumnIndex -lt 0) -or ($ColumnIndex -ge $ListView.Columns.Count))
	{
		return;
	}
	
	#region Define ListViewItemComparer
	try
	{
		[ListViewItemComparer] | Out-Null
	}
	catch
	{
		Add-Type -ReferencedAssemblies ('System.Windows.Forms') -TypeDefinition  @" 
	using System;
	using System.Windows.Forms;
	using System.Collections;
	public class ListViewItemComparer : IComparer
	{
	    public int column;
	    public SortOrder sortOrder;
	    public ListViewItemComparer()
	    {
	        column = 0;
			sortOrder = SortOrder.Ascending;
	    }
	    public ListViewItemComparer(int column, SortOrder sort)
	    {
	        this.column = column;
			sortOrder = sort;
	    }
	    public int Compare(object x, object y)
	    {
			if(column >= ((ListViewItem)x).SubItems.Count)
				return  sortOrder == SortOrder.Ascending ? -1 : 1;
		
			if(column >= ((ListViewItem)y).SubItems.Count)
				return sortOrder == SortOrder.Ascending ? 1 : -1;
		
			if(sortOrder == SortOrder.Ascending)
	        	return String.Compare(((ListViewItem)x).SubItems[column].Text, ((ListViewItem)y).SubItems[column].Text);
			else
				return String.Compare(((ListViewItem)y).SubItems[column].Text, ((ListViewItem)x).SubItems[column].Text);
	    }
	}
"@ | Out-Null
	}
	#endregion
	
	if ($ListView.Tag -is [ListViewItemComparer])
	{
		#Toggle the Sort Order
		if ($SortOrder -eq [System.Windows.Forms.SortOrder]::None)
		{
			if ($ListView.Tag.column -eq $ColumnIndex -and $ListView.Tag.sortOrder -eq 'Ascending')
			{
				$ListView.Tag.sortOrder = 'Descending'
			}
			else
			{
				$ListView.Tag.sortOrder = 'Ascending'
			}
		}
		else
		{
			$ListView.Tag.sortOrder = $SortOrder
		}
		
		$ListView.Tag.column = $ColumnIndex
		$ListView.Sort() #Sort the items
	}
	else
	{
		if ($SortOrder -eq [System.Windows.Forms.SortOrder]::None)
		{
			$SortOrder = [System.Windows.Forms.SortOrder]::Ascending
		}
		
		#Set to Tag because for some reason in PowerShell ListViewItemSorter prop returns null
		$ListView.Tag = New-Object ListViewItemComparer ($ColumnIndex, $SortOrder)
		$ListView.ListViewItemSorter = $ListView.Tag #Automatically sorts
	}
}



function Add-ListViewItem
{
<#
	.SYNOPSIS
		Adds the item(s) to the ListView and stores the object in the ListViewItem's Tag property.

	.DESCRIPTION
		Adds the item(s) to the ListView and stores the object in the ListViewItem's Tag property.

	.PARAMETER ListView
		The ListView control to add the items to.

	.PARAMETER Items
		The object or objects you wish to load into the ListView's Items collection.
		
	.PARAMETER  ImageIndex
		The index of a predefined image in the ListView's ImageList.
	
	.PARAMETER  SubItems
		List of strings to add as Subitems.
	
	.PARAMETER Group
		The group to place the item(s) in.
	
	.PARAMETER Clear
		This switch clears the ListView's Items before adding the new item(s).
	
	.EXAMPLE
		Add-ListViewItem -ListView $listview1 -Items "Test" -Group $listview1.Groups[0] -ImageIndex 0 -SubItems "Installed"
#>
	
	Param( 
	[ValidateNotNull()]
	[Parameter(Mandatory=$true)]
	[System.Windows.Forms.ListView]$ListView,
	[ValidateNotNull()]
	[Parameter(Mandatory=$true)]
	$Items,
	[int]$ImageIndex = -1,
	[string[]]$SubItems,
	$Group,
	[switch]$Clear)
	
	if($Clear)
	{
		$ListView.Items.Clear();
    }
    
    $lvGroup = $null
    if ($Group -is [System.Windows.Forms.ListViewGroup])
    {
        $lvGroup = $Group
    }
    elseif ($Group -is [string])
    {
        #$lvGroup = $ListView.Group[$Group] # Case sensitive
        foreach ($groupItem in $ListView.Groups)
        {
            if ($groupItem.Name -eq $Group)
            {
                $lvGroup = $groupItem
                break
            }
        }
        
        if ($null -eq $lvGroup)
        {
            $lvGroup = $ListView.Groups.Add($Group, $Group)
        }
    }
    
	if($Items -is [Array])
	{
		$ListView.BeginUpdate()
		foreach ($item in $Items)
		{		
			$listitem  = $ListView.Items.Add($item.ToString(), $ImageIndex)
			#Store the object in the Tag
			$listitem.Tag = $item
			
			if($null -ne $SubItems)
			{
				$listitem.SubItems.AddRange($SubItems)
			}
			
			if($null -ne $lvGroup)
			{
				$listitem.Group = $lvGroup
			}
		}
		$ListView.EndUpdate()
	}
	else
	{
		#Add a new item to the ListView
		$listitem  = $ListView.Items.Add($Items.ToString(), $ImageIndex)
		#Store the object in the Tag
		$listitem.Tag = $Items
		
		if($null -ne $SubItems)
		{
			$listitem.SubItems.AddRange($SubItems)
		}
		
		if($null -ne $lvGroup)
		{
			$listitem.Group = $lvGroup
		}
	}
}


#endregion

$buttonДобавитьПодписку_Click = {
	if (Show-addSubscriptionForm_psf -eq 'OK')
	{
		$baseDir = [System.AppDomain]::CurrentDomain.BaseDirectory
		$profilesDir = Join-Path $baseDir "profiles"
		if (-not (Test-Path -LiteralPath $profilesDir))
		{
			[System.IO.Directory]::CreateDirectory($profilesDir) | Out-Null
		}
		
		$listBox1.Items.Clear()
		Get-ChildItem -Path $profilesDir -File | ForEach-Object {
			$listbox1.Items.Add($_.Name)
		}
	}
}

$labelДобавитьПрофиль_Click={
	if (Show-addSubscriptionForm_psf -eq 'OK')
	{
		$baseDir = [System.AppDomain]::CurrentDomain.BaseDirectory
		$profilesDir = Join-Path $baseDir "profiles"
		if (-not (Test-Path -LiteralPath $profilesDir))
		{
			[System.IO.Directory]::CreateDirectory($profilesDir) | Out-Null
		}
		
		$listBox1.Items.Clear()
		Get-ChildItem -Path $profilesDir -File | ForEach-Object {
			$listbox1.Items.Add($_.Name)
		}
	}
}

$listbox1_DoubleClick = {
	if ($listbox1.SelectedItem)
	{
		$script:SelectedFileName = $listbox1.SelectedItem.ToString()
		$label1.Text = $script:SelectedFileName
	}
}

$buttonСтоп_Click={
	try
	{
		if ($script:SingBoxProcess -and -not $script:SingBoxProcess.HasExited)
		{
			Stop-Process -Id $script:SingBoxProcess.Id -Force
			Start-Sleep -Milliseconds 500
		}
		
		$script:SingBoxProcess = $null
		Update-SingBoxStatus
		Hide-ExternalIpLabels
	}
	catch
	{
		[System.Windows.Forms.MessageBox]::Show("Не удалось остановить:`r`n$($_.Exception.Message)")
	}
	
}

$timerStatus_Tick={
	Update-SingBoxStatus
	
}

$labelУдалитьПрофиль_Click={
	if (Show-DeleteProfileForm_psf -eq 'OK')
	{
		$listBox1.Items.Clear()
		Get-ChildItem -Path $profilesDir -File | ForEach-Object {
			$listbox1.Items.Add($_.Name)
		}
	}
	
}

