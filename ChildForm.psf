	}
	
}



#$script:AllowClose = $false

$formEasyBox_FormClosing = {
	param ($sender,
		$e)
	
	if ($script:AllowClose)
	{
		Cleanup-App
		return
	}
	
	$result = [System.Windows.Forms.MessageBox]::Show(
		"Закрыть приложение? VPN перестанет работать.",
		"Закрыть?",
		[System.Windows.Forms.MessageBoxButtons]::YesNo,
		[System.Windows.Forms.MessageBoxIcon]::Warning
	)
	
	if ($result -eq [System.Windows.Forms.DialogResult]::Yes)
	{
		$script:AllowClose = $true
		Cleanup-App
		$e.Cancel = $false
	}
	else
	{
		$e.Cancel = $true
	}
}

$formEasyBox_SizeChanged = {
	if ($formEasyBox.WindowState -eq [System.Windows.Forms.FormWindowState]::Minimized)
	{
		$formEasyBox.ShowInTaskbar = $false
		$formEasyBox.Hide()
		$notifyicon1.Visible = $true
	}
}

$notifyicon1_DoubleClick = {
	$formEasyBox.Show()
	$formEasyBox.ShowInTaskbar = $true
	$formEasyBox.WindowState = [System.Windows.Forms.FormWindowState]::Normal
	$formEasyBox.Activate()
}

