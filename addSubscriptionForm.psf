  <Code><![CDATA[function Save-SingboxProfileFromSubscriptionUrl
{
	[CmdletBinding()]
	param (
		[Parameter(Mandatory)]
		[string]$Url,
		[Parameter()]
		[string]$ProxyTag = "proxy",
		[hashtable]$Headers
	)
	
	Add-Type -AssemblyName System.Windows.Forms
	
	function Show-UiMessage
	{
		param (
			[Parameter(Mandatory)]
			[string]$Text,
			[string]$Title = "Message",
			[System.Windows.Forms.MessageBoxIcon]$Icon = [System.Windows.Forms.MessageBoxIcon]::Information
		)
		
		[void][System.Windows.Forms.MessageBox]::Show(
			$Text,
			$Title,
			[System.Windows.Forms.MessageBoxButtons]::OK,
			$Icon
		)
	}
	
	function ConvertFrom-Base64UrlOrPlain
	{
		param (
			[Parameter(Mandatory)]
			[string]$Text
		)
		
		$trimmed = $Text.Trim()
		
		if ([string]::IsNullOrWhiteSpace($trimmed))
		{
			return $null
		}
		
		if ($trimmed -match '^\s*vless://')
		{
			return $trimmed
		}
		
		try
		{
			$candidate = ($trimmed -replace '\s+', '')
			$normalized = $candidate.Replace('-', '+').Replace('_', '/')
			
			switch ($normalized.Length % 4)
			{
				2 { $normalized += '==' }
				3 { $normalized += '=' }
			}
			
			$bytes = [Convert]::FromBase64String($normalized)
			return [System.Text.Encoding]::UTF8.GetString($bytes)
		}
		catch
		{
			return $trimmed
		}
	}
	
	function Parse-VlessLinkToSingboxOutbound
	{
		param (
			[Parameter(Mandatory)]
			[string]$Link,
			[Parameter(Mandatory)]
			[string]$ProxyTag
		)
		
		$link = $Link.Trim()
		
		if (-not $link.StartsWith('vless://'))
		{
			throw "Only vless:// links are supported."
		}
		
		$uriNoScheme = $link.Substring('vless://'.Length)
		
		$hashIndex = $uriNoScheme.IndexOf('#')
		if ($hashIndex -ge 0)
		{
			$beforeFragment = $uriNoScheme.Substring(0, $hashIndex)
			$fragment = $uriNoScheme.Substring($hashIndex + 1)
			$nodeName = [System.Uri]::UnescapeDataString($fragment)
		}
		else
		{
			$beforeFragment = $uriNoScheme
			$nodeName = $null
		}
		
		$qIndex = $beforeFragment.IndexOf('?')
		if ($qIndex -ge 0)
		{
			$authorityPart = $beforeFragment.Substring(0, $qIndex)
			$queryPart = $beforeFragment.Substring($qIndex + 1)
		}
		else
		{
			$authorityPart = $beforeFragment
			$queryPart = ""
		}
		
		$atIndex = $authorityPart.LastIndexOf('@')
		if ($atIndex -lt 0)
		{
			throw "Invalid VLESS URI: missing '@'."
		}
		
		$uuid = $authorityPart.Substring(0, $atIndex)
		$hostPort = $authorityPart.Substring($atIndex + 1)
		
		$colonIndex = $hostPort.LastIndexOf(':')
		if ($colonIndex -lt 0)
		{
			throw "Invalid VLESS URI: missing port."
		}
		
		$server = $hostPort.Substring(0, $colonIndex)
		$serverPort = [int]$hostPort.Substring($colonIndex + 1)
		
		$queryParams = @{ }
		if ($queryPart)
		{
			foreach ($pair in ($queryPart -split '&'))
			{
				if (-not $pair) { continue }
				
				$kv = $pair -split '=', 2
				$key = [System.Uri]::UnescapeDataString($kv[0])
				$value = if ($kv.Count -gt 1)
				{
					[System.Uri]::UnescapeDataString($kv[1])
				}
				else
				{
					""
				}
				
				$queryParams[$key] = $value
			}
		}
		
		$outbound = [ordered]@{
			tag		    = $ProxyTag
			type	    = "vless"
			server	    = $server
			server_port = $serverPort
			uuid	    = $uuid
		}
		
		if ($queryParams.ContainsKey('flow') -and $queryParams['flow'])
		{
			$outbound.flow = $queryParams['flow']
		}
		
		$tls = [ordered]@{
			enabled = $true
		}
		
		if ($queryParams.ContainsKey('sni') -and $queryParams['sni'])
		{
			$tls.server_name = $queryParams['sni']
		}
		
		if ($queryParams.ContainsKey('fp') -and $queryParams['fp'])
		{
			$tls.utls = [ordered]@{
				enabled	    = $true
				fingerprint = $queryParams['fp']
			}
		}
		
		if ($queryParams.ContainsKey('security') -and $queryParams['security'] -eq 'reality')
		{
			$reality = [ordered]@{
				enabled = $true
			}
			
			if ($queryParams.ContainsKey('pbk') -and $queryParams['pbk'])
			{
				$reality.public_key = $queryParams['pbk']
			}
			
			if ($queryParams.ContainsKey('sid') -and $queryParams['sid'])
			{
				$reality.short_id = $queryParams['sid']
			}
			
			$tls.reality = $reality
		}
		
		$outbound.tls = $tls
		
		if ($queryParams.ContainsKey('packetEncoding') -and $queryParams['packetEncoding'])
		{
			$outbound.packet_encoding = $queryParams['packetEncoding']
		}
		
		if ($queryParams.ContainsKey('type') -and $queryParams['type'] -and $queryParams['type'] -ne 'tcp')
		{
			$outbound.transport = [ordered]@{
				type = $queryParams['type']
			}
		}
		
		[pscustomobject]@{
			NodeName = $nodeName
			Outbound = $outbound
			RawLink  = $link
		}
	}
	
	try
	{
		$inputText = $Url.Trim()
		
		if ([string]::IsNullOrWhiteSpace($inputText))
		{
			throw "Empty URL or VLESS link."
		}
		
		$firstLink = $null
		
		# 1. Если введена сразу vless:// ссылка
		if ($inputText -match '^\s*vless://')
		{
			$firstLink = $inputText
		}
		# 2. Если введена http/https ссылка на подписку
		elseif ($inputText -match '^\s*https?://')
		{
			try
			{
				$invokeParams = @{
					Uri			    = $inputText
					UseBasicParsing = $true
					ErrorAction	    = 'Stop'
				}
				
				if ($Headers)
				{
					$invokeParams.Headers = $Headers
				}
				
				$response = Invoke-WebRequest @invokeParams
				$rawContent = $response.Content
			}
			catch
			{
				throw "Failed to download subscription."
			}
			
			if ([string]::IsNullOrWhiteSpace($rawContent))
			{
				throw "Subscription content is empty."
			}
			
			$decodedContent = ConvertFrom-Base64UrlOrPlain -Text $rawContent
			
			$links = @(
				$decodedContent -split "`r?`n" |
				ForEach-Object { $_.Trim() } |
				Where-Object { $_ -and $_ -match '^vless://' }
			)
			
			if (-not $links -or $links.Count -eq 0)
			{
				throw "No vless:// links found in subscription."
			}
			
			$firstLink = $links | Select-Object -First 1
		}
		else
		{
			throw "Enter either http/https subscription URL or vless:// link."
		}
		
		$parsed = Parse-VlessLinkToSingboxOutbound -Link $firstLink -ProxyTag $ProxyTag
		$profile = $parsed.Outbound
		
		$json = $profile | ConvertTo-Json -Depth 20
		
		# Папка рядом с exe/скриптом
		$baseDir = [System.AppDomain]::CurrentDomain.BaseDirectory
		$profilesDir = Join-Path $baseDir "profiles"
		
		if (-not (Test-Path -LiteralPath $profilesDir))
		{
			[System.IO.Directory]::CreateDirectory($profilesDir) | Out-Null
		}
		
		$SafeName = $parsed.NodeName
		if ([string]::IsNullOrWhiteSpace($SafeName))
		{
			$SafeName = "$($profile.server)_$($profile.server_port)"
		}
		
		$SafeName = $SafeName -replace '[\\/:*?"<>|]', '_'
		$OutFile = Join-Path $profilesDir ($SafeName)
		
		[System.IO.File]::WriteAllText($OutFile, $json, [System.Text.UTF8Encoding]::new($false))
		
		Show-UiMessage -Text "Профиль '$SafeName' добавлен." -Title "Готово" -Icon Information
		
		return [pscustomobject]@{
			SourceUrl  = $inputText
			OutputFile = $OutFile
			NodeName   = $parsed.NodeName
			ProxyTag   = $ProxyTag
			Server	   = $profile.server
			Port	   = $profile.server_port
		}
	}
	catch
	{
		Show-UiMessage -Text $_.Exception.Message -Title "Error" -Icon Error
		return $null
	}
}

$buttonДобавитьПрофиль_Click={
	
		$result = Save-SingboxProfileFromSubscriptionUrl -Url $textbox2.Text -ProxyTag "proxy"
}


$labelОчистить_Click={
	$textbox2.Text =""
}


$buttonЗакрыть_Click={
	
	
}
]]></Code>
  <Mode>0</Mode>
  <Assemblies />
</File>